<launch>
    <node pkg="tf" type="static_transform_publisher" name="odom_to_base" args="0 0 0 0 0 0 odom base_link 100" />
    <node pkg="tf" type="static_transform_publisher" name="base_to_camera" args="0 0 0 0 0 0 base_link camera_link 100" />

    <node type="point_cloud_assembler" pkg="laser_assembler" name="my_assembler">
        <remap from="cloud" to="cam_pcd"/>
        <param name="max_clouds" type="int" value="1" />
        <param name="fixed_frame" type="string" value="map" />
        <param name="tf_cache_time_secs" type="double" value="1.0" />
    </node>

    <node pkg="mapping" name="manual_mapping" type="manual_mapping" output="screen">
        <param name="min_cam_d" type="double" value="-5.0" />
        <param name="max_cam_d" type="double" value="5.0" />
        <param name="maxf_points_out" type="double" value="15.0" />
        <param name="maxf_map_out" type="double" value="1.0" />
    </node>
</launch>

