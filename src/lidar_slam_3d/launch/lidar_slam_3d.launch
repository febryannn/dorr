<launch>
    <param name="use_sim_time" value="false"/>

    <node name="lidar_slam_3d" pkg="lidar_slam_3d" type="lidar_slam_3d" output="screen">
        <param name="base_frame"           value="base_link"/>
        <param name="map_frame"            value="map"/>
        <param name="odom_frame"           value="odom"/>
        <param name="sensor_frame"         value="camera_link"/>
        <param name="publish_freq"         value="0.4"/>
        <param name="min_scan_distance"    value="0.5"/>
        <param name="point_cloud_topic"    value="cloud"/>
        <param name="odom_topic"           value="odom"/>
        <param name="laser_topic1"          value="scan1"/>
        <param name="laser_topic2"          value="scan2"/>
        <param name="laser_topic3"          value="scan3"/>
        <param name="enable_floor_filter"  value="false"/>
    </node>

  <node pkg="lidar_slam_3d" type="slam3d_to_grid_node" name="slam_to_grid" output="screen" >
    <!-- center offset position xy -->
    <param name="position_x" value="0.5"/>
    <param name="position_y" value="3.0"/>
    <!-- size of a grid cell -->
    <param name="cell_size" value="0.02"/>
    <param name="length_x" value="13.0"/>
    <param name="length_y" value="9.0"/>
    <!-- <param name="cloud_in_topic" value="/os_cloud_node/points"/> -->
    <param name="cloud_in_topic" value="/map_cloud"/>
    <!-- <param name="frame_out" value="os1_sensor"/> -->
    <param name="mapi_topic_name" value="mapgrid_i"/>
    <param name="maph_topic_name" value="mapgrid_h"/>
    <param name="intensity_factor" value="125.0"/>
    <param name="height_factor" value="125.0"/>
  </node>
  
</launch>
