<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="agv_robot">

  <xacro:property name="wheel_radius" value="0.1" />
  <xacro:property name="wheel_width" value="0.05" />

  <link name="base_footprint"/>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/> 
      <geometry><mesh filename="file://$(find agv_sim)/meshes/agv.stl" scale="1 1 1"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>
    </visual>
    <collision><geometry><box size="0.8 0.5 0.3"/></geometry></collision>
    <inertial><mass value="25.0"/><inertia ixx="0.5" ixy="0.0" ixz="0.0" iyy="0.5" iyz="0.0" izz="0.5"/></inertial>
  </link>

  <xacro:macro name="wheel" params="name y">
    <link name="${name}_link">
      <visual><origin xyz="0 0 0" rpy="${pi/2} 0 0"/><geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry></visual>
      <collision><origin xyz="0 0 0" rpy="${pi/2} 0 0"/><geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry></collision>
      <inertial><mass value="2.0"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
    </link>
    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/><child link="${name}_link"/><origin xyz="0 ${y} -0.1" rpy="0 0 0"/><axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel name="left_wheel"  y="0.25"/>
  <xacro:wheel name="right_wheel" y="-0.25"/>

  <xacro:macro name="caster" params="name x">
    <link name="${name}_link">
      <visual><geometry><sphere radius="0.048"/></geometry><material name="black"><color rgba="0 0 0 1"/></material></visual>
      <collision><geometry><sphere radius="0.048"/></geometry></collision>
      <inertial><mass value="0.5"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/><child link="${name}_link"/><origin xyz="${x} 0 -0.15" rpy="0 0 0"/>
    </joint>
    <gazebo reference="${name}_link">
      <mu1>0.0</mu1><mu2>0.0</mu2>
      <material>Gazebo/Black</material>
    </gazebo>
  </xacro:macro>

  <xacro:caster name="front_caster" x="0.3"/>
  <xacro:caster name="rear_caster" x="-0.3"/>

  <xacro:macro name="kinect_v1" params="name x y yaw topic">
    <link name="${name}_link">
      <visual><geometry><box size="0.05 0.12 0.04"/></geometry><material name="blue"><color rgba="0 0 0.8 1"/></material></visual>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/><child link="${name}_link"/><origin xyz="${x} ${y} 0.4" rpy="0 0 ${yaw}"/>
    </joint>
    <gazebo reference="${name}_link">
      <sensor name="${name}" type="depth_camera">
        <update_rate>20</update_rate>
        <topic>${topic}</topic>
        <gz_frame_id>${name}_link</gz_frame_id>
        <camera><horizontal_fov>1.047</horizontal_fov><image><width>640</width><height>480</height></image><clip><near>0.5</near><far>8.0</far></clip></camera>
      </sensor>
    </gazebo>
  </xacro:macro>

  <xacro:kinect_v1 name="camera_link_1" x="0.4"  y="0.0"  yaw="0.0"     topic="cloud_in1"/>
  <xacro:kinect_v1 name="camera_link_2" x="-0.4" y="0.0"  yaw="3.1415"  topic="cloud_in2"/>
  <xacro:kinect_v1 name="camera_link_3" x="0.0"  y="0.25" yaw="1.5708"  topic="cloud_in3"/>
  <xacro:kinect_v1 name="camera_link_4" x="0.0"  y="-0.25" yaw="-1.5708" topic="cloud_in4"/>

  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.5</wheel_separation>
      <wheel_radius>0.1</wheel_radius>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states</topic>
    </plugin>
  </gazebo>
</robot>
